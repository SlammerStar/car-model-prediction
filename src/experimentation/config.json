            "market_stability_score", "market_liquidity_score",
            "brand_resale_retention_score", "historical_brand_depreciation",
            "age_based_depreciation", "usage_based_depreciation", "remaining_life_index"
        ],
        "pruned_engineered": [
            "brand", "model", "transmission", "fuelType",
            "car_age", "km_per_year",
            "vehicle_segment", "engine_performance_score",
            "seller_type_score",
            "market_liquidity_score", "configuration_scarcity_score",
